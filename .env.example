# Enables live literature/source checks. Set to 0 for fully offline deterministic demo mode.
AI_SCIENTIST_LOAD_DOTENV=1
AI_SCIENTIST_LIVE_QC=1

# Optional tuning for live source requests.
AI_SCIENTIST_SOURCE_TIMEOUT_SECONDS=20
AI_SCIENTIST_SOURCE_MAX_WORKERS=8
AI_SCIENTIST_USER_AGENT=ai-scientist-hackathon/0.1 (mailto:your-email@example.com)
AI_SCIENTIST_QC_SEARCH_QUERY_LIMIT=4

# Optional advanced QC pipeline.
# Requires OPENAI_API_KEY for embeddings and TAVILY_API_KEY for web search.
# If disabled or missing credentials, the app falls back to deterministic QC.
AI_SCIENTIST_ADVANCED_QC=0
AI_SCIENTIST_ADVANCED_QC_MAX_RESULTS=10
AI_SCIENTIST_TAVILY_SEARCH_DEPTH=basic
AI_SCIENTIST_TAVILY_INCLUDE_RAW_CONTENT=0
AI_SCIENTIST_EMBEDDING_MODEL=text-embedding-3-small
AI_SCIENTIST_EMBEDDING_DIMENSIONS=512

# Optional LLM query expansion for better literature recall.
# The app still works without this; it falls back to deterministic query variants.
AI_SCIENTIST_LLM_QUERY_EXPANSION=0
AI_SCIENTIST_LLM_PROVIDER=openai
AI_SCIENTIST_LLM_MODEL=gpt-4o-mini
AI_SCIENTIST_LLM_TIMEOUT_SECONDS=15
AI_SCIENTIST_LLM_MAX_QUERIES=5

# Optional API keys / identity fields.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TAVILY_API_KEY=

# Semantic Scholar works without a key at low volume but may rate-limit anonymous traffic.
SEMANTIC_SCHOLAR_API_KEY=

# protocols.io public API requires a bearer token from https://www.protocols.io/developers
PROTOCOLS_IO_TOKEN=

# NCBI works without a key at low volume. Email/tool improve compliance and rate limits.
NCBI_API_KEY=
NCBI_EMAIL=
NCBI_TOOL=ai_scientist_hackathon

# Crossref works without a key. mailto opts into the polite pool.
CROSSREF_MAILTO=
